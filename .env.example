# MiniMax API (推荐 - 中国区可用)
VITE_MINIMAX_API_KEY=your_minimax_api_key_here
VITE_MINIMAX_MODEL=MiniMax-M2.7
VITE_MINIMAX_BASE_URL=https://api.minimaxi.chat/v1

# 火山引擎 API (可选)
VITE_VOLCANO_API_KEY=your_volcano_api_key_here
VITE_VOLCANO_ENDPOINT_ID=your_endpoint_id_here
VITE_VOLCANO_MODEL=doubao-seed-2.0-lite

# SMS API (可选，不填则使用模拟模式)
VITE_SMS_API_URL=/api/sms
