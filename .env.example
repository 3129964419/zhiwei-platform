# 火山引擎 API 配置
VITE_VOLCANO_API_KEY=your_volcano_api_key
VITE_VOLCANO_ENDPOINT_ID=your_endpoint_id
VITE_VOLCANO_MODEL=your_endpoint_id

# MiniMax API 配置（可选）
VITE_MINIMAX_API_KEY=your_minimax_api_key
VITE_MINIMAX_MODEL=MiniMax-M2.7
VITE_MINIMAX_BASE_URL=https://api.minimaxi.chat/v1

# SMS 验证码服务配置
# 部署 SMS 服务后填写，未配置则使用模拟模式
VITE_SMS_API_URL=https://your-sms-service.vercel.app
